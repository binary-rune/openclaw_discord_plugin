{
  "name": "openclaw-discord-bridge",
  "version": "1.0.0",
  "description": "Standalone Discord bridge for OpenClaw with full proxy support (fixes issue #27409)",
  "main": "dist/bridge.js",
  "types": "dist/bridge.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "start": "node dist/bridge.js",
    "start:dev": "ts-node src/bridge.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "openclaw",
    "discord",
    "bridge",
    "proxy",
    "messaging"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1",
    "https-proxy-agent": "^7.0.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}