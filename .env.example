# OpenClaw Discord Bridge - Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Discord bot token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Auth token for OpenClaw HTTP API
# Generate with: openssl rand -hex 32
# Then set in OpenClaw: openclaw config set http.authToken "YOUR_TOKEN" --json
OPENCLAW_AUTH_TOKEN=YOUR_GENERATED_TOKEN_HERE

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# OpenClaw HTTP API URL (default: http://127.0.0.1:18789)
OPENCLAW_HTTP_URL=http://127.0.0.1:18789

# HTTP/HTTPS/SOCKS proxy URL (default: http://127.0.0.1:7890)
# This is the KEY setting that fixes issue #27409
# Supports: http://, https://, socks4://, socks5://
PROXY_URL=http://127.0.0.1:7890

# DM policy: open, pairing, allowlist, disabled
DM_POLICY=open

# Guild policy: open, allowlist, disabled
GROUP_POLICY=allowlist

# Device ID for session management
DEVICE_ID=openclaw-discord-bridge

# Allowed user IDs for DMs (comma-separated, for allowlist mode)
ALLOW_FROM=123456789,987654321

# Gateway intents
INTENT_MESSAGE_CONTENT=true
INTENT_SERVER_MEMBERS=true
INTENT_PRESENCE=false

# Bot status: online, idle, dnd, invisible
BOT_STATUS=online

# Activity type: 0=Playing, 1=Streaming, 2=Listening, 3=Watching, 4=Custom
ACTIVITY_TYPE=2

# Activity name (shown in bot status)
ACTIVITY=OpenClaw Bridge

# Activity URL (required for Streaming type)
# ACTIVITY_URL=https://twitch.tv/your_channel